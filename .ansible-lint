---
exclude_paths:
    - "**/.github/**"
    - .ansible-lint
    - "**/.ansible/**"
    - "roles/**/defaults/**"  # explicit role defaults exclusion
    - "**/defaults/**"      # exclude any defaults dir anywhere
    - "**/vars/**"          # exclude any vars dir anywhere
    - "**/molecule/**"     # exclude any molecule dir anywhere
    - "**/meta/**"         # exclude any meta dir anywhere
    - "roles/**/meta/**"  # explicit role meta exclusion
    - galaxy.yml
    - "**/changelogs/**"
    - devfile.yaml
    - collections/requirements.yml

    - roles/bootstrap_controller/files/job_templates/**
    - roles/bootstrap_controller/files/job_templates.disabled/**
    - roles/bootstrap_controller/files/workflows/**
    - roles/bootstrap_controller/templates/workflows/**
    - roles/bootstrap_generate_playbook_repo/files/playbooks/**
