exclude_paths:
    - "**/.github/**"
    - .ansible-lint
    - "**/.ansible/**"
    - "roles/**/defaults/**"  # explicit role defaults exclusion
    - "**/defaults/**"      # exclude any defaults dir anywhere
    - "**/vars/**"          # exclude any vars dir anywhere
    - "**/molecule/**"     # exclude any molecule dir anywhere
    - "**/meta/**"         # exclude any meta dir anywhere
    - "roles/**/meta/**"  # explicit role meta exclusion
    - galaxy.yml
    - "**/changelogs/**"
    - devfile.yaml
    - collections/requirements.yml

mock_modules:
  - ansible.posix.mount
  - infra.ado.ocp_namespace
  - infra.ado.ocp_operatorgroups
  - infra.ado.ocp_wait_pods
  - infra.ado.ocp_routes
  - redhat.satellite.registration_command
  - redhat.satellite.host
  - redhat.rhel_idm.ipaclient
  - redhat.rhel_idm.dnsrecord
  - redhat.rhel_idm.ipareplica
  - redhat.rhel_idm.ipaserver
  - redhat.rhel_system_roles.mount
  - redhat.satellite.content_view
  - redhat.satellite.content_view_version
  - awx.awx.organization
  - awx.awx.credential
  - awx.awx.project
  - awx.awx.inventory
  - awx.awx.host
  - awx.awx.label
  - awx.awx.execution_environment
  - awx.awx.job_template
  - redhat.openshift_virtualization.kubevirt_vm
  - community.crypto.openssh_keypair
  - grafana.grafana.folder
  - grafana.grafana.dashboard
  - redhat.rhbk.keycloak_user_federation
  - redhat.rhbk.keycloak_realm
  - redhat.rhbk.keycloak_group
  - redhat.rhbk.keycloak_user
  - redhat.rhbk.keycloak_client
  - redhat.rhbk.keycloak_role
  - redhat.rhbk.keycloak_role_mapping
  - redhat.rhbk.keycloak_user_role_mapping
  - redhat.rhbk.keycloak_user_group_mapping
  - redhat.rhbk.keycloak_client_scope
  - redhat.rhbk.keycloak_client_scope_group_mapper
  - kubernetes.core.k8s
  - kubernetes.core.k8s_info
  - kubernetes.core.k8s_exec 
  - kubernetes.core.helm_repository 
  - kubernetes.core.helm 
