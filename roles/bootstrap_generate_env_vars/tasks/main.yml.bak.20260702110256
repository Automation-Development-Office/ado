---
- name: Load preflight JSON input
  ansible.builtin.set_fact:
    bootstrap_generate_env_vars_preflight: "{{ lookup('ansible.builtin.file', preflight_json) | from_json }}"
  when:
    - preflight_json is defined
    - preflight_json | length > 0

- name: Set values from preflight JSON
  ansible.builtin.set_fact:
    bootstrap_generate_env_vars_env: "{{ bootstrap_generate_env_vars_preflight.environment | default('prod') }}"
    bootstrap_generate_env_vars_base_domain: "{{ bootstrap_generate_env_vars_preflight.domain | default('prod.rhlab') }}"
    bootstrap_generate_env_vars_component: "{{ bootstrap_generate_env_vars_preflight.component | default('all') }}"
    bootstrap_generate_env_vars_platform: >-
      {{
        (bootstrap_generate_env_vars_preflight.platform | default(['all']))[0] | lower
        if (bootstrap_generate_env_vars_preflight.platform | default(['all'])) is sequence
        and (bootstrap_generate_env_vars_preflight.platform | default(['all'])) is not string
        else (bootstrap_generate_env_vars_preflight.platform | default('all') | lower)
      }}
    bootstrap_generate_env_vars_components: >-
      {{
        [bootstrap_generate_env_vars_preflight.component | default('all')]
        if bootstrap_generate_env_vars_preflight.component is defined
        else
        (
          ['openshift', 'keycloak', 'satellite', 'grafana', 'jira', 'patching']
          if 'all' in ((bootstrap_generate_env_vars_preflight.platform | default(['all'])) | map('lower') | list)
          else ((bootstrap_generate_env_vars_preflight.platform | default(['all'])) | map('lower') | list)
        )
      }}
    bootstrap_generate_env_vars_use_aap: "{{ (bootstrap_generate_env_vars_preflight.aap | default({})).enabled | default(true) | bool }}"
    bootstrap_generate_env_vars_enable_jira: "{{ (bootstrap_generate_env_vars_preflight.jira | default({})).enabled | default(false) | bool }}"
  when: bootstrap_generate_env_vars_preflight is defined

- name: Validate env was provided
  ansible.builtin.assert:
    that:
      - env is defined
      - env | string | length > 0
    fail_msg: |
      Environment must be provided.

      Example:
      ansible-playbook -c local -i inventory run-ado-scaffolding.yml \
        -e env=prod \
        --vault-password-file ~/.vault_pass

- name: Set internal env variable from provided env
  ansible.builtin.set_fact:
    bootstrap_generate_env_vars_env: "{{ env }}"

- name: Set environment directory
  ansible.builtin.set_fact:
    bootstrap_generate_env_vars_env_dir: "{{ bootstrap_generate_env_vars_base_dir | default(generate_env_vars_base_dir | default('group_vars/all')) }}/{{ bootstrap_generate_env_vars_env }}"

- name: Ask whether to create/update repo directories
  ansible.builtin.pause:
    prompt: "Create/update generated bootstrap repository files and directory structure? [Y/n]"
  register: bootstrap_generate_env_vars_prompt_create_dirs
  when: bootstrap_generate_env_vars_preflight is not defined

- name: Set create dirs answer interactive
  ansible.builtin.set_fact:
    bootstrap_generate_env_vars_create_dirs: "{{ (bootstrap_generate_env_vars_prompt_create_dirs.user_input | default('y', true) | lower) not in ['n', 'no'] }}"
  when: bootstrap_generate_env_vars_preflight is not defined

- name: Set create dirs answer preflight
  ansible.builtin.set_fact:
    bootstrap_generate_env_vars_create_dirs: true
  when: bootstrap_generate_env_vars_preflight is defined

- name: Ensure generated repo directories exist
  ansible.builtin.file:
    path: "{{ item }}"
    state: directory
    mode: "0755"
  loop:
    - "{{ bootstrap_generate_env_vars_env_dir }}"
    - "{{ playbook_dir }}/playbooks"
    - "{{ playbook_dir }}/configs"
    - "{{ playbook_dir }}/configs/controller"
    - "{{ playbook_dir }}/configs/job_templates"
    - "{{ playbook_dir }}/configs/workflows"
  when: bootstrap_generate_env_vars_create_dirs | bool

- name: Ask for base domain
  ansible.builtin.pause:
    prompt: "What is the base environment domain? (example: example.com)"
  register: bootstrap_generate_env_vars_prompt_base_domain
  when: bootstrap_generate_env_vars_preflight is not defined

- name: Set base domain interactive
  ansible.builtin.set_fact:
    bootstrap_generate_env_vars_base_domain: "{{ bootstrap_generate_env_vars_prompt_base_domain.user_input }}"
  when: bootstrap_generate_env_vars_preflight is not defined

- name: Ensure base domain was provided
  ansible.builtin.assert:
    that:
      - bootstrap_generate_env_vars_base_domain is defined
      - bootstrap_generate_env_vars_base_domain | length > 0
    fail_msg: "Base domain is required."

- name: Ask platform
  ansible.builtin.pause:
    prompt: "Platform [all/openshift/linux]"
  register: bootstrap_generate_env_vars_prompt_platform
  when: bootstrap_generate_env_vars_preflight is not defined

- name: Set platform answer interactive
  ansible.builtin.set_fact:
    bootstrap_generate_env_vars_platform: "{{ bootstrap_generate_env_vars_prompt_platform.user_input | default('all', true) | lower }}"
  when: bootstrap_generate_env_vars_preflight is not defined

- name: Ask OpenShift questions
  when:
    - bootstrap_generate_env_vars_preflight is not defined
    - bootstrap_generate_env_vars_platform in ['all', 'openshift']
  block:
    - name: Ask OpenShift API host
      ansible.builtin.pause:
        prompt: "OpenShift API host"
      register: bootstrap_generate_env_vars_prompt_ocp_host

    - name: Ask OpenShift domain
      ansible.builtin.pause:
        prompt: "OpenShift domain"
      register: bootstrap_generate_env_vars_prompt_ocp_domain

- name: Set all components when platform is all
  ansible.builtin.set_fact:
    bootstrap_generate_env_vars_components:
      - openshift
      - keycloak
      - satellite
      - grafana
      - jira
      - patching
  when:
    - bootstrap_generate_env_vars_preflight is not defined
    - bootstrap_generate_env_vars_platform == 'all'

- name: Ask for enabled components when platform is not all
  ansible.builtin.pause:
    prompt: >-
      What additional components do you want to enable?
      (comma separated)
      Options: openshift,keycloak,satellite,grafana,jira,patching
  register: bootstrap_generate_env_vars_prompt_components
  when:
    - bootstrap_generate_env_vars_preflight is not defined
    - bootstrap_generate_env_vars_platform != 'all'

- name: Set enabled components when platform is openshift
  ansible.builtin.set_fact:
    bootstrap_generate_env_vars_components: >-
      {{
        (
          ['openshift'] +
          (
            bootstrap_generate_env_vars_prompt_components.user_input
            | default('', true)
            | lower
            | replace(' ', '')
            | split(',')
            | reject('equalto', '')
            | list
          )
        )
        | unique
        | list
      }}
  when:
    - bootstrap_generate_env_vars_preflight is not defined
    - bootstrap_generate_env_vars_platform == 'openshift'

- name: Set enabled components when platform is linux
  ansible.builtin.set_fact:
    bootstrap_generate_env_vars_components: >-
      {{
        (
          bootstrap_generate_env_vars_prompt_components.user_input
          | default('patching', true)
          | lower
          | replace(' ', '')
          | split(',')
          | reject('equalto', '')
          | list
        )
        | unique
        | list
      }}
  when:
    - bootstrap_generate_env_vars_preflight is not defined
    - bootstrap_generate_env_vars_platform == 'linux'

- name: Show selected components
  ansible.builtin.debug:
    var: bootstrap_generate_env_vars_components

- name: Find existing generated component vars files
  ansible.builtin.find:
    paths:
      - "{{ bootstrap_generate_env_vars_env_dir }}"
    patterns:
      - "vars_*.yml"
    file_type: file
  register: bootstrap_generate_env_vars_existing_component_vars

- name: Find existing generated component vault files
  ansible.builtin.find:
    paths:
      - "{{ bootstrap_generate_env_vars_env_dir }}"
    patterns:
      - "vault_*.yml"
    file_type: file
  register: bootstrap_generate_env_vars_existing_component_vaults

- name: Remove stale generated component vars files
  ansible.builtin.file:
    path: "{{ item.path }}"
    state: absent
  loop: "{{ bootstrap_generate_env_vars_existing_component_vars.files }}"
  when:
    - item.path | basename not in (
        bootstrap_generate_env_vars_components
        | map('regex_replace', '^(.*)$', 'vars_\\1.yml')
        | list
      )

- name: Remove stale generated component vault files
  ansible.builtin.file:
    path: "{{ item.path }}"
    state: absent
  loop: "{{ bootstrap_generate_env_vars_existing_component_vaults.files }}"
  when:
    - item.path | basename not in (
        bootstrap_generate_env_vars_components
        | map('regex_replace', '^(.*)$', 'vault_\\1.yml')
        | list
      )

- name: Write component vars files
  ansible.builtin.template:
    src: component_vars.yml.j2
    dest: "{{ bootstrap_generate_env_vars_env_dir }}/vars_{{ component_name }}.yml"
    mode: "0644"
    force: "{{ bootstrap_generate_env_vars_force | bool }}"
  loop: "{{ bootstrap_generate_env_vars_components }}"
  loop_control:
    loop_var: component_name

- name: Write component vault files
  ansible.builtin.template:
    src: component_vault.yml.j2
    dest: "{{ bootstrap_generate_env_vars_env_dir }}/vault_{{ component_name }}.yml"
    mode: "0600"
    force: "{{ bootstrap_generate_env_vars_force | bool }}"
  loop: "{{ bootstrap_generate_env_vars_components }}"
  loop_control:
    loop_var: component_name

- name: Ask if using AAP
  ansible.builtin.pause:
    prompt: "Are you using AAP? [Y/n]"
  register: bootstrap_generate_env_vars_prompt_use_aap
  when: bootstrap_generate_env_vars_preflight is not defined

- name: Set AAP enabled answer interactive
  ansible.builtin.set_fact:
    bootstrap_generate_env_vars_use_aap: "{{ (bootstrap_generate_env_vars_prompt_use_aap.user_input | default('y', true) | lower) not in ['n', 'no'] }}"
  when: bootstrap_generate_env_vars_preflight is not defined

- name: Ask AAP questions
  when:
    - bootstrap_generate_env_vars_preflight is not defined
    - bootstrap_generate_env_vars_use_aap | bool
  block:
    - name: Ask AAP hostname
      ansible.builtin.pause:
        prompt: "AAP hostname"
      register: bootstrap_generate_env_vars_prompt_aap_hostname

    - name: Ask AAP OAuth token
      ansible.builtin.pause:
        prompt: "AAP OAuth token"
        echo: false
      register: bootstrap_generate_env_vars_prompt_aap_token

    - name: Ask AAP admin username
      ansible.builtin.pause:
        prompt: "AAP admin username [admin]"
      register: bootstrap_generate_env_vars_prompt_aap_username

    - name: Ask AAP admin password
      ansible.builtin.pause:
        prompt: "AAP admin password"
        echo: false
      register: bootstrap_generate_env_vars_prompt_aap_password

    - name: Ask AAP version
      ansible.builtin.pause:
        prompt: "AAP version [2.4/2.5/2.6]"
      register: bootstrap_generate_env_vars_prompt_aap_version

    - name: Ask AAP organization
      ansible.builtin.pause:
        prompt: "AAP organization"
      register: bootstrap_generate_env_vars_prompt_aap_org

    - name: Ask AAP inventory name
      ansible.builtin.pause:
        prompt: "AAP inventory name"
      register: bootstrap_generate_env_vars_prompt_aap_inventory

    - name: Ask AAP project name
      ansible.builtin.pause:
        prompt: "AAP project name"
      register: bootstrap_generate_env_vars_prompt_aap_project

    - name: Ask AAP project Git URL
      ansible.builtin.pause:
        prompt: "AAP project Git URL"
      register: bootstrap_generate_env_vars_prompt_aap_project_scm_url

    - name: Ask AAP project Git branch
      ansible.builtin.pause:
        prompt: "AAP project Git branch [main]"
      register: bootstrap_generate_env_vars_prompt_aap_project_scm_branch

    - name: Ask AAP project Git token
      ansible.builtin.pause:
        prompt: "AAP project Git token [blank to skip]"
        echo: false
      register: bootstrap_generate_env_vars_prompt_aap_project_scm_token
      when:
        - bootstrap_generate_env_vars_preflight is not defined
        - generate_playbook_repo_git_push | default(true) | bool

    - name: Ask whether to auto push generated repo
      ansible.builtin.pause:
        prompt: "Automatically commit and push generated repo to Git? [y/N]"
      register: bootstrap_generate_env_vars_prompt_git_auto_push
      when:
        - bootstrap_generate_env_vars_preflight is not defined

    - name: Ask AAP default execution environment
      ansible.builtin.pause:
        prompt: "AAP default execution environment [ee-supported-rhel9]"
      register: bootstrap_generate_env_vars_prompt_aap_ee

    - name: Ask AAP vault credential name
      ansible.builtin.pause:
        prompt: "AAP vault credential name"
      register: bootstrap_generate_env_vars_prompt_aap_vault_cred

    - name: Ask whether to enable Jira
      ansible.builtin.pause:
        prompt: "Enable Jira issue tracker? [y/N]"
      register: bootstrap_generate_env_vars_prompt_enable_jira

    - name: Set Jira enabled answer
      ansible.builtin.set_fact:
        bootstrap_generate_env_vars_enable_jira: >-
          {{
            (bootstrap_generate_env_vars_prompt_enable_jira.user_input
             | default('n', true)
             | lower)
            in ['y', 'yes']
          }}

    - name: Ask Jira questions
      when: bootstrap_generate_env_vars_enable_jira | bool
      block:
        - name: Ask Jira URL
          ansible.builtin.pause:
            prompt: "Jira URL"
          register: bootstrap_generate_env_vars_prompt_jira_url

        - name: Ask Jira project key
          ansible.builtin.pause:
            prompt: "Jira project key"
          register: bootstrap_generate_env_vars_prompt_jira_project_key

        - name: Ask Jira custom AC field
          ansible.builtin.pause:
            prompt: "Jira custom AC field [blank for null]"
          register: bootstrap_generate_env_vars_prompt_jira_custom_ac_field

        - name: Ask whether to enable Jira subtasks
          ansible.builtin.pause:
            prompt: "Enable Jira subtasks? [Y/n]"
          register: bootstrap_generate_env_vars_prompt_jira_create_subtasks

        - name: Ask Jira templates directory
          ansible.builtin.pause:
            prompt: "Jira templates dir [blank for null]"
          register: bootstrap_generate_env_vars_prompt_jira_templates_dir

        - name: Ask Jira username
          ansible.builtin.pause:
            prompt: "Jira username"
          register: bootstrap_generate_env_vars_prompt_jira_username

        - name: Ask Jira token
          ansible.builtin.pause:
            prompt: "Jira token"
            echo: false
          register: bootstrap_generate_env_vars_prompt_jira_token

- name: Normalize AAP version interactive
  ansible.builtin.set_fact:
    bootstrap_generate_env_vars_aap_version_number: >-
      {% set v = (bootstrap_generate_env_vars_prompt_aap_version.user_input
                  | default('2.6', true)
                  | replace(',', '.')
                  | trim) %}
      {% if v == '2.4' %}
      24
      {% elif v == '2.5' %}
      25
      {% elif v == '2.6' %}
      26
      {% elif v == '2.7' %}
      27
      {% else %}
      26
      {% endif %}
  when:
    - bootstrap_generate_env_vars_use_aap | bool

- name: Write AAP config vars
  ansible.builtin.template:
    src: aap_config_vars.yml.j2
    dest: "{{ bootstrap_generate_env_vars_env_dir }}/aap_config_vars.yml"
    mode: "0644"
    force: "{{ bootstrap_generate_env_vars_force | bool }}"
  when:
    - bootstrap_generate_env_vars_use_aap | bool

- name: Write AAP vault vars
  ansible.builtin.template:
    src: aap_vault.yml.j2
    dest: "{{ bootstrap_generate_env_vars_env_dir }}/aap_vault.yml"
    mode: "0600"
    force: "{{ bootstrap_generate_env_vars_force | bool }}"
  when:
    - bootstrap_generate_env_vars_use_aap | bool

- name: Write Jira vault file
  ansible.builtin.template:
    src: vault_jira.yml.j2
    dest: "{{ bootstrap_generate_env_vars_env_dir }}/vault_jira.yml"
    mode: "0600"
    force: "{{ bootstrap_generate_env_vars_force | bool }}"
  when:
    - bootstrap_generate_env_vars_use_aap | bool
    - bootstrap_generate_env_vars_enable_jira | default(false) | bool

- name: Set vault encryption from preflight JSON
  ansible.builtin.set_fact:
    bootstrap_generate_env_vars_encrypt_vault_files: "{{ bootstrap_generate_env_vars_preflight.vault.encrypt | default(false) | bool }}"
  when: bootstrap_generate_env_vars_preflight is defined

- name: Ask whether to encrypt generated vault files
  ansible.builtin.pause:
    prompt: "Encrypt generated vault files with ansible-vault? [Y/n]"
  register: bootstrap_generate_env_vars_prompt_encrypt_vault_files
  when:
    - bootstrap_generate_env_vars_encrypt_vault_files is not defined
    - bootstrap_generate_env_vars_preflight is not defined

- name: Set vault encryption answer
  ansible.builtin.set_fact:
    bootstrap_generate_env_vars_encrypt_vault_files: >-
      {{
        (bootstrap_generate_env_vars_prompt_encrypt_vault_files.user_input
         | default('y', true)
         | lower)
        not in ['n', 'no']
      }}
  when:
    - bootstrap_generate_env_vars_encrypt_vault_files is not defined
    - bootstrap_generate_env_vars_preflight is not defined

- name: Ask for vault password when encrypting vault files
  ansible.builtin.pause:
    prompt: "Vault password"
    echo: false
  register: bootstrap_generate_env_vars_prompt_vault_password
  when:
    - bootstrap_generate_env_vars_encrypt_vault_files | bool
    - bootstrap_generate_env_vars_preflight is not defined

- name: Create temporary vault password file
  ansible.builtin.tempfile:
    state: file
    suffix: vault-pass
  register: bootstrap_generate_env_vars_temp_vault_password_file
  when:
    - bootstrap_generate_env_vars_encrypt_vault_files | bool
    - bootstrap_generate_env_vars_preflight is not defined

- name: Write temporary vault password file
  ansible.builtin.copy:
    dest: "{{ bootstrap_generate_env_vars_temp_vault_password_file.path }}"
    content: "{{ bootstrap_generate_env_vars_prompt_vault_password.user_input }}"
    mode: "0600"
  when:
    - bootstrap_generate_env_vars_encrypt_vault_files | bool
    - bootstrap_generate_env_vars_preflight is not defined

- name: Find generated vault files
  ansible.builtin.find:
    paths: "{{ bootstrap_generate_env_vars_env_dir }}"
    patterns: "vault*.yml,*_vault.yml"
    file_type: file
  register: bootstrap_generate_env_vars_vault_files
  when:
    - bootstrap_generate_env_vars_encrypt_vault_files | bool
    - bootstrap_generate_env_vars_preflight is not defined

- name: Check generated vault file encryption state
  ansible.builtin.command:
    cmd: "head -n 1 {{ item.path }}"
  loop: "{{ bootstrap_generate_env_vars_vault_files.files | default([]) }}"
  register: bootstrap_generate_env_vars_vault_file_headers
  changed_when: false
  when:
    - bootstrap_generate_env_vars_encrypt_vault_files | bool
    - bootstrap_generate_env_vars_preflight is not defined

- name: Encrypt generated vault files
  ansible.builtin.command:
    cmd: >-
      ansible-vault encrypt {{ item.item.path }}
      --vault-password-file {{ bootstrap_generate_env_vars_temp_vault_password_file.path }}
  loop: "{{ bootstrap_generate_env_vars_vault_file_headers.results | default([]) }}"
  when:
    - bootstrap_generate_env_vars_encrypt_vault_files | bool
    - item.stdout is not search('^\\$ANSIBLE_VAULT;')
  changed_when: true

- name: Remove temporary vault password file
  ansible.builtin.file:
    path: "{{ bootstrap_generate_env_vars_temp_vault_password_file.path }}"
    state: absent
  when:
    - bootstrap_generate_env_vars_encrypt_vault_files | bool
    - bootstrap_generate_env_vars_temp_vault_password_file.path is defined
