---
# Generated by infra.ado.bootstrap_generate_env_vars
# Component vault: {{ component_name }}

{% if component_name == 'aap' %}
aap_admin_user: admin
aap_admin_password: redhat123
aap_token_oauth: ""

{% elif component_name == 'aap24' %}
aap24_admin_user: admin
aap24_admin_password: redhat123

{% elif component_name == 'acs' %}
acs_admin_user: admin
acs_admin_password: redhat123

{% elif component_name == '389ds' %}
components_vault:
  389ds:
    ds_suffix: "dc=prod,dc=rhlab"
    dirsrv_manager_password: redhat123
    repl_manager_password: redhat123
    test_user_uid: testuser

{% elif component_name == 'grafana' %}
grafana_admin_user: admin
grafana_admin_password: redhat123

{% elif component_name == 'satellite' %}
vault_satellite_service_account_username: "{{ bootstrap_generate_env_vars_satellite_service_account_username | default('') }}"
vault_satellite_service_account_password: "{{ bootstrap_generate_env_vars_satellite_service_account_password | default('') }}"
vault_satellite_admin_password: "{{ bootstrap_generate_env_vars_satellite_admin_password | default(bootstrap_generate_env_vars_satellite_service_account_password | default('')) }}"
vault_satellite_rhn_org_id: "{{ bootstrap_generate_env_vars_satellite_rhn_org_id | default('') }}"
vault_satellite_rhn_activation_key: "{{ bootstrap_generate_env_vars_satellite_rhn_activation_key | default('') }}"
satellite_install_satellite_admin_password: "{% raw %}{{ vault_satellite_admin_password }}{% endraw %}"
satellite_install_rhn_org_id: "{% raw %}{{ vault_satellite_rhn_org_id }}{% endraw %}"
satellite_install_rhn_activation_key: "{% raw %}{{ vault_satellite_rhn_activation_key }}{% endraw %}"

{% elif component_name == 'htpasswd' %}
htpasswd_users:
  - name: admin
    password: redhat123
    role: cluster-admin
  - name: chad-adm
    password: knuckle
    role: cluster-admin
  - name: developer
    password: redhat123
    role: developer

htpasswd_pass: redhat123

{% elif component_name == 'cert_manager' %}
tls_crt:
tls_key:

{% elif component_name == 'openshift' %}
htpasswd_users:
  - name: admin
    password: redhat123
    role: cluster-admin
htpasswd_pass: redhat123
ocp_awspca_access_key_id: ""
ocp_awspca_secret_access_key: ""

{% elif component_name == 'openshift_virt' %}
{% set openshift_virt_config = bootstrap_generate_env_vars_preflight.component_config.openshift_virt | default({}) if bootstrap_generate_env_vars_preflight is defined else {} %}
provision_openshift_virt_api_token: "{{ openshift_virt_config.api_token | default(bootstrap_generate_env_vars_openshift_virt_api_token | default(''), true) }}"

{% elif component_name == 'gitlab' %}
gitlab_tls_crt:
gitlab_tls_key:
gitlab_root_user: root
gitlab_root_password: redhat123

{% elif component_name == 'rhbk' %}
rhbk_tls_cert:
rhbk_tls_key:
rhbk_admin_user: admin
rhbk_admin_password: redhat123

rhbk_federation_name: LDAP

ldap_config:
  enabled: "true"
  vendor: rhds
  connectionUrl: ldap://idm.server.lab
  bindDn: "cn=Directory Manager"
  bindCredential: knuckle01
  usersDn: "cn=users,cn=accounts,dc=server,dc=lab"
  authType: simple
  useTruststoreSpi: ldapsOnly
  editMode: READ_ONLY
  syncRegistrations: "false"
  priority: "0"
  cachePolicy: DEFAULT
  usernameLDAPAttribute: uid
  rdnLDAPAttribute: uid
  uuidLDAPAttribute: nsuniqueid
  userObjectClasses: inetOrgPerson

ldap_group_config:
  groups.dn: "cn=groups,cn=accounts,dc=server,dc=lab"
  group.name.ldap.attribute: cn
  group.object.classes: groupOfNames
  preserve.group.inheritance: "true"
  ignore.missing.groups: "false"
  membership.ldap.attribute: member
  membership.attribute.type: DN
  membership.user.ldap.attribute: dn
  mode: READ_ONLY
  user.roles.retrieve.strategy: LOAD_GROUPS_BY_MEMBER_ATTRIBUTE

{% elif component_name == 'quay' %}
quay_admin_user: admin
quay_admin_password: redhat123

{% else %}
# No default vault vars for this component yet.
{% endif %}
