---
# Generated by infra.ado.bootstrap_generate_env_vars
# Component: {{ component_name }}

{% if component_name == 'aap' %}
components_env:
  aap:
    storage_class: synology-nfs-csi

{% elif component_name == 'aap24' %}
components_env:
  aap24:
    projects_persistence: true
    projects_storage_class: synology-nfs-csi
    projects_storage_size: 8Gi
    projects_storage_access_mode: ReadWriteMany
    cert_issuer_kind: ClusterIssuer
    cert_issuer_name: idm-acme
    controller_tls_secret: controller24-route-tls
    aap24_activate_subscription: false
    aap24_subscription_method: manifest
    aap24_subscription_manifest_path: ""

{% elif component_name == '389ds' %}
components_env:
  389ds:
    storage_class_name: synology-nfs-csi
    expected_replicas: 2
    enable_certificate: false
    dirsrv_cleanup: true
    enable_bootstrap_templates: true

{% elif component_name == 'gitlab' %}
components_env:
  gitlab:
    storage_class: synology-nfs-csi
    storage: synology-nfs-csi

{% elif component_name == 'grafana' %}
components_env:
  grafana:
    operator_channel: "5.20.0"
    operator_starting_csv: ""
    grafana_folder: OpenshiftProd
    storage: synology-nfs-csi
    oidc:
      enabled: true
      client_id: grafana_client
      default_role: Viewer
      role_map:
        - group: ocp-cluster-admin
          role: GrafanaAdmin
        - group: ocp-cluster-devel
          role: Viewer
        - group: ocp-cluster-ops
          role: Editor
        - group: ocp-cluster-readonly
          role: Viewer

{% elif component_name == 'kafka' %}
components_env:
  kafka:
    operator_channel: "2.11"
    operator_starting_csv: ""

{% elif component_name == 'satellite' %}
satellite_config_server_url: "{{ bootstrap_generate_env_vars_satellite_server_url | default('') }}"
{% if bootstrap_generate_env_vars_satellite_service_account_username is defined %}
satellite_config_username: "{{ bootstrap_generate_env_vars_satellite_service_account_username }}"
{% else %}
satellite_config_username: "{% raw %}{{ vault_satellite_service_account_username | default(omit) }}{% endraw %}"
{% endif %}
satellite_config_password: "{% raw %}{{ vault_satellite_service_account_password | default(omit) }}{% endraw %}"
satellite_config_admin_password: "{% raw %}{{ vault_satellite_admin_password | default(vault_satellite_service_account_password | default(omit)) }}{% endraw %}"
satellite_config_organization: "{{ bootstrap_generate_env_vars_satellite_organization | default('') }}"
satellite_config_validate_certs: {{ bootstrap_generate_env_vars_satellite_validate_certs | default(false) | bool | lower }}
satellite_config_satellite_deployment_version: "{{ bootstrap_generate_env_vars_satellite_deployment_version | default('6.19', true) }}"
satellite_install_deployment_version: "{{ bootstrap_generate_env_vars_satellite_deployment_version | default('6.19', true) }}"
satellite_install_location: "{{ bootstrap_generate_env_vars_satellite_location | default('') }}"
satellite_install_rhn_connected: {{ ((bootstrap_generate_env_vars_satellite_rhn_org_id | default('') | length) > 0 and (bootstrap_generate_env_vars_satellite_rhn_activation_key | default('') | length) > 0) | bool | lower }}
satellite_install_rhn_org_id: "{% raw %}{{ vault_satellite_rhn_org_id | default(omit) }}{% endraw %}"
satellite_install_rhn_activation_key: "{% raw %}{{ vault_satellite_rhn_activation_key | default(omit) }}{% endraw %}"
satellite_install_size_profile: "{{ bootstrap_generate_env_vars_satellite_size_profile | default('default') }}"
satellite_install_size:
{{ bootstrap_generate_env_vars_satellite_size | to_nice_yaml(indent=2) | indent(2, true) }}
{% set selected_satellite_size = (bootstrap_generate_env_vars_satellite_size | default([]) | selectattr('name', 'equalto', bootstrap_generate_env_vars_satellite_size_profile | default('default')) | first | default({})) %}
satellite_install_min_memory_size: {{ (selected_satellite_size.min_ram | default(20) | int) * 1024 }}
satellite_install_min_cpu_count: {{ selected_satellite_size.min_cpu | default(4) | int }}
satellite_install_vg_name: "{{ bootstrap_generate_env_vars_satellite_vg_name | default('satellite', true) }}"
satellite_install_req_dirs:
{{ bootstrap_generate_env_vars_satellite_req_dirs | to_nice_yaml(indent=2) | indent(2, true) }}
satellite_install_data_disk_min_size: "{{ bootstrap_generate_env_vars_satellite_data_disk_min_size | default('10G', true) }}"
satellite_install_data_device_name: "{{ bootstrap_generate_env_vars_satellite_data_device_name | default('', true) }}"
satellite_install_data_device: "{{ bootstrap_generate_env_vars_satellite_data_device | default('/dev', true) }}"

{% elif component_name == 'eck' %}
components_env:
  eck:
    operator_starting_csv: "elasticsearch-eck-operator-certified.v3.0.0"

{% elif component_name == 'quay' %}
components_env:
  quay:
    storage: synology-nfs-csi

{% elif component_name == 'openshift' %}
ocp_cert_manager_mode: cert
ocp_awspca_namespace: cert-manager
ocp_awspca_secret_name: awspca-creds
ocp_awspca_issuer_name: awspca-clusterissuer
ocp_awspca_region: us-gov-west-1
ocp_awspca_pca_arn: ""
idm:
  acme_directory_url: ""
  ca_bundle_file: ""

{% elif component_name == 'openshift_virt' %}
{% set openshift_virt_config = bootstrap_generate_env_vars_preflight.component_config.openshift_virt | default({}) if bootstrap_generate_env_vars_preflight is defined else {} %}
provision_openshift_virt_api_host: {{ openshift_virt_config.api_host | default(bootstrap_generate_env_vars_openshift_virt_api_host | default(''), true) | to_json }}
provision_openshift_virt_skip_tls_verify: {{ openshift_virt_config.skip_tls_verify | default(bootstrap_generate_env_vars_openshift_virt_skip_tls_verify | default(true)) | bool | lower }}
provision_openshift_virt_namespace: {{ bootstrap_generate_env_vars_openshift_virt_namespace | default('default', true) | to_json }}
provision_openshift_virt_vm_name: {{ bootstrap_generate_env_vars_openshift_virt_vm_name | default('satellite-server', true) | to_json }}
provision_openshift_virt_hostname: {{ bootstrap_generate_env_vars_openshift_virt_hostname | default('satellite-server', true) | to_json }}
provision_openshift_virt_source_kind: {{ bootstrap_generate_env_vars_openshift_virt_source_kind | default('DataSource', true) | to_json }}
provision_openshift_virt_source_name: {{ bootstrap_generate_env_vars_openshift_virt_source_name | default('rhel9', true) | to_json }}
provision_openshift_virt_source_namespace: {{ bootstrap_generate_env_vars_openshift_virt_source_namespace | default('openshift-virtualization-os-images', true) | to_json }}
provision_openshift_virt_instance_type: {{ bootstrap_generate_env_vars_openshift_virt_instance_type | default('u1.xlarge', true) | to_json }}
provision_openshift_virt_preference: {{ bootstrap_generate_env_vars_openshift_virt_preference | default('rhel.9', true) | to_json }}
provision_openshift_virt_cpu_cores: {{ bootstrap_generate_env_vars_openshift_virt_cpu_cores | default(4, true) | int }}
provision_openshift_virt_memory: {{ bootstrap_generate_env_vars_openshift_virt_memory | default('20Gi', true) | to_json }}
provision_openshift_virt_storage_class: {{ bootstrap_generate_env_vars_openshift_virt_storage_class | default('', true) | to_json }}
provision_openshift_virt_root_disk_size: {{ bootstrap_generate_env_vars_openshift_virt_root_disk_size | default('120Gi', true) | to_json }}
provision_openshift_virt_network_name: {{ bootstrap_generate_env_vars_openshift_virt_network_name | default('default', true) | to_json }}
provision_openshift_virt_cloud_user: {{ bootstrap_generate_env_vars_openshift_virt_cloud_user | default('cloud-user', true) | to_json }}
provision_openshift_virt_ssh_public_key: {{ openshift_virt_config.ssh_public_key | default(bootstrap_generate_env_vars_openshift_virt_ssh_public_key | default(''), true) | to_json }}
provision_openshift_virt_enable_root_ssh: {{ bootstrap_generate_env_vars_openshift_virt_enable_root_ssh | default(false) | bool | lower }}
provision_openshift_virt_interface_name: {{ bootstrap_generate_env_vars_openshift_virt_interface_name | default('eth0', true) | to_json }}
provision_openshift_virt_static_ip: {{ bootstrap_generate_env_vars_openshift_virt_static_ip | default('', true) | to_json }}
provision_openshift_virt_prefix_length: {{ bootstrap_generate_env_vars_openshift_virt_prefix_length | default(24, true) | int }}
provision_openshift_virt_gateway: {{ bootstrap_generate_env_vars_openshift_virt_gateway | default('', true) | to_json }}
provision_openshift_virt_dns_servers: {{ bootstrap_generate_env_vars_openshift_virt_dns_servers | default([], true) | to_json }}
provision_openshift_virt_app_label: {{ bootstrap_generate_env_vars_openshift_virt_app_label | default('satellite-server', true) | to_json }}
provision_openshift_virt_start: {{ bootstrap_generate_env_vars_openshift_virt_start | default(true) | bool | lower }}
provision_openshift_virt_wait_timeout: {{ bootstrap_generate_env_vars_openshift_virt_wait_timeout | default(3600, true) | int }}

{% elif component_name == 'rhbk' %}
components_env:
  rhbk:
    storage: synology-nfs-csi
    rhbk_realm: rhlab
    rhbk_no_log: false
    cert_manager: true
    rhbk_issuer_name: idm-acme
    rhbk_issuer_kind: ClusterIssuer
    rhbk_clients:
      openshift-prod:
        rhbk_client_name: "OpenShift Prod"
        rhbk_description: "Prod OIDC"
        rhbk_service_accounts_enabled: true
        rhbk_public_client: false
        rhbk_redirect_uris:
          - "https://oauth-openshift.{{ '{{ app_domain }}' }}/oauth2callback/Keycloak/*"
        rhbk_web_origins:
          - "https://oauth-openshift.{{ '{{ app_domain }}' }}"
      openshift_dev:
        client_id: openshift-dev
        rhbk_client_name: "OpenShift Dev"
      grafana_client:
        rhbk_client_name: "Grafana Prod"
        rhbk_description: "Prod Grafana OIDC"
        rhbk_service_accounts_enabled: true
        rhbk_public_client: false
        rhbk_redirect_uris:
          - "https://grafana.{{ '{{ app_domain }}' }}/login/generic_oauth"
          - "https://grafana.{{ '{{ app_domain }}' }}/*"
        rhbk_web_origins:
          - "https://grafana.{{ '{{ app_domain }}' }}"
    openshift_oidc_auth:
      keycloak_client_id: "openshift-prod"
      openshift_oidc_idp_name: "Keycloak"
      issuer: "https://keycloak.{{ '{{ app_domain }}' }}/realms/rhlab"
      extra_scopes:
        - openid
        - email
        - profile
        - groups

{% elif component_name == 'ldap_auth_openshift' %}
components_env:
  ldap_auth_openshift:
    openshift_ldap_auth:
      idp_name: LDAP_IDM

{% elif component_name == 'pega' %}
k8s_auth_verify_ssl: false

pega_namespace: pega
pega_deployment_name: pega
pega_app_domain: ocp.prod.rhlab

pega_local_images:
  - src_tar: /data/pega/pega_23_1_1.tar
    source_image: "pega-docker.downloads.pega.com/platform/pega:23.1.1"
    target_image: "pega/pega:23.1.1"
  - src_tar: /data/pega/pega_srs.tar
    source_image: "pega-docker.downloads.pega.com/platform-services/search-n-reporting-service-os:1.35.0"
    target_image: "pega/search-n-reporting-service-os:1.35.0"
  - src_tar: /data/pega/pega_23_install.tar
    source_image: "pega-docker.downloads.pega.com/platform/installer:23.1.1"
    target_image: "pega/installer:23.1.1"

pega_kafka_bootstrap_server: "pega-kafka-cluster-kafka-bootstrap.pega.svc.cluster.local:9092"

{% elif component_name == 'rhel' %}
components_env:
  rhel:
    hostname: ''
    compliance_profile: PCI-DSS
    stig_profile: RHEL 9 STIG

{% elif component_name == 'stig' %}
compliance_profile: STIG
stig_profile: RHEL 9 STIG
rhel_stig_profile: RHEL 9 STIG

{% elif component_name == 'compliance' %}
components_env:
  compliance:
    profile: PCI-DSS

{% else %}
# No default vars for this component yet.
{% endif %}
