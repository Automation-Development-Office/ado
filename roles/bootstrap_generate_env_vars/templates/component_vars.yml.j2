---
# Generated by infra.ado.bootstrap_generate_env_vars
# Component: {{ component_name }}

{% if component_name == 'aap' %}
components_env:
  aap:
    storage_class: synology-nfs-csi

{% elif component_name == 'aap24' %}
components_env:
  aap24:
    projects_persistence: true
    projects_storage_class: synology-nfs-csi
    projects_storage_size: 8Gi
    projects_storage_access_mode: ReadWriteMany
    cert_issuer_kind: ClusterIssuer
    cert_issuer_name: idm-acme
    controller_tls_secret: controller24-route-tls
    aap24_activate_subscription: false
    aap24_subscription_method: manifest
    aap24_subscription_manifest_path: ""

{% elif component_name == '389ds' %}
components_env:
  389ds:
    storage_class_name: synology-nfs-csi
    expected_replicas: 2
    enable_certificate: false
    dirsrv_cleanup: true
    enable_bootstrap_templates: true

{% elif component_name == 'gitlab' %}
components_env:
  gitlab:
    storage_class: synology-nfs-csi
    storage: synology-nfs-csi

{% elif component_name == 'grafana' %}
components_env:
  grafana:
    operator_channel: "5.20.0"
    operator_starting_csv: ""
    grafana_folder: OpenshiftProd
    storage: synology-nfs-csi
    oidc:
      enabled: true
      client_id: grafana_client
      default_role: Viewer
      role_map:
        - group: ocp-cluster-admin
          role: GrafanaAdmin
        - group: ocp-cluster-devel
          role: Viewer
        - group: ocp-cluster-ops
          role: Editor
        - group: ocp-cluster-readonly
          role: Viewer

{% elif component_name == 'kafka' %}
components_env:
  kafka:
    operator_channel: "2.11"
    operator_starting_csv: ""

{% elif component_name == 'satellite' %}
satellite_config_server_url: "{{ bootstrap_generate_env_vars_satellite_server_url | default('') }}"
{% if bootstrap_generate_env_vars_satellite_service_account_username is defined %}
satellite_config_username: "{{ bootstrap_generate_env_vars_satellite_service_account_username }}"
{% else %}
satellite_config_username: "{% raw %}{{ vault_satellite_service_account_username | default(omit) }}{% endraw %}"
{% endif %}
satellite_config_password: "{% raw %}{{ vault_satellite_service_account_password | default(omit) }}{% endraw %}"
satellite_config_admin_password: "{% raw %}{{ vault_satellite_admin_password | default(vault_satellite_service_account_password | default(omit)) }}{% endraw %}"
satellite_config_organization: "{{ bootstrap_generate_env_vars_satellite_organization | default('') }}"
satellite_config_validate_certs: {{ bootstrap_generate_env_vars_satellite_validate_certs | default(false) | bool | lower }}

{% elif component_name == 'eck' %}
components_env:
  eck:
    operator_starting_csv: "elasticsearch-eck-operator-certified.v3.0.0"

{% elif component_name == 'quay' %}
components_env:
  quay:
    storage: synology-nfs-csi

{% elif component_name == 'openshift' %}
ocp_console_banner_text: "Hello! ADO OpenShift"
ocp_console_banner_location: BannerTop
ocp_console_banner_background_color: "#1f7a1f"
ocp_console_banner_text_color: "#ffffff"
ocp_cert_manager_mode: cert
ocp_awspca_namespace: cert-manager
ocp_awspca_secret_name: awspca-creds
ocp_awspca_issuer_name: awspca-clusterissuer
ocp_awspca_region: us-gov-west-1
ocp_awspca_pca_arn: ""
idm:
  acme_directory_url: ""
  ca_bundle_file: ""

{% elif component_name == 'rhbk' %}
components_env:
  rhbk:
    storage: synology-nfs-csi
    rhbk_realm: rhlab
    rhbk_no_log: false
    cert_manager: true
    rhbk_issuer_name: idm-acme
    rhbk_issuer_kind: ClusterIssuer
    rhbk_clients:
      openshift-prod:
        rhbk_client_name: "OpenShift Prod"
        rhbk_description: "Prod OIDC"
        rhbk_service_accounts_enabled: true
        rhbk_public_client: false
        rhbk_redirect_uris:
          - "https://oauth-openshift.{{ '{{ app_domain }}' }}/oauth2callback/Keycloak/*"
        rhbk_web_origins:
          - "https://oauth-openshift.{{ '{{ app_domain }}' }}"
      openshift_dev:
        client_id: openshift-dev
        rhbk_client_name: "OpenShift Dev"
      grafana_client:
        rhbk_client_name: "Grafana Prod"
        rhbk_description: "Prod Grafana OIDC"
        rhbk_service_accounts_enabled: true
        rhbk_public_client: false
        rhbk_redirect_uris:
          - "https://grafana.{{ '{{ app_domain }}' }}/login/generic_oauth"
          - "https://grafana.{{ '{{ app_domain }}' }}/*"
        rhbk_web_origins:
          - "https://grafana.{{ '{{ app_domain }}' }}"
    openshift_oidc_auth:
      keycloak_client_id: "openshift-prod"
      openshift_oidc_idp_name: "Keycloak"
      issuer: "https://keycloak.{{ '{{ app_domain }}' }}/realms/rhlab"
      extra_scopes:
        - openid
        - email
        - profile
        - groups

{% elif component_name == 'ldap_auth_openshift' %}
components_env:
  ldap_auth_openshift:
    openshift_ldap_auth:
      idp_name: LDAP_IDM

{% elif component_name == 'pega' %}
k8s_auth_verify_ssl: false

pega_namespace: pega
pega_deployment_name: pega
pega_app_domain: ocp.prod.rhlab

pega_local_images:
  - src_tar: /data/pega/pega_23_1_1.tar
    source_image: "pega-docker.downloads.pega.com/platform/pega:23.1.1"
    target_image: "pega/pega:23.1.1"
  - src_tar: /data/pega/pega_srs.tar
    source_image: "pega-docker.downloads.pega.com/platform-services/search-n-reporting-service-os:1.35.0"
    target_image: "pega/search-n-reporting-service-os:1.35.0"
  - src_tar: /data/pega/pega_23_install.tar
    source_image: "pega-docker.downloads.pega.com/platform/installer:23.1.1"
    target_image: "pega/installer:23.1.1"

pega_kafka_bootstrap_server: "pega-kafka-cluster-kafka-bootstrap.pega.svc.cluster.local:9092"

{% elif component_name == 'rhel' %}
components_env:
  rhel:
    hostname: ''
    compliance_profile: PCI-DSS
    stig_profile: RHEL 9 STIG

{% elif component_name == 'stig' %}
compliance_profile: STIG
stig_profile: RHEL 9 STIG
rhel_stig_profile: RHEL 9 STIG

{% elif component_name == 'compliance' %}
components_env:
  compliance:
    profile: PCI-DSS

{% else %}
# No default vars for this component yet.
{% endif %}
