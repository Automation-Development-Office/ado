{% set preflight_aap = generate_env_vars_preflight.aap | default({}) %}
---
{% set generate_env_vars_aap_org = preflight_aap.organization if generate_env_vars_preflight is defined else generate_env_vars_prompt_aap_org.user_input %}
{% set generate_env_vars_aap_inventory = preflight_aap.inventory if generate_env_vars_preflight is defined else generate_env_vars_prompt_aap_inventory.user_input %}
{% set generate_env_vars_aap_project = preflight_aap.project if generate_env_vars_preflight is defined else generate_env_vars_prompt_aap_project.user_input %}
{% set generate_env_vars_aap_ee = preflight_aap.execution_environment if generate_env_vars_preflight is defined else (generate_env_vars_prompt_aap_ee.user_input | default('ee-supported-rhel9', true)) %}
{% set generate_env_vars_aap_cred = preflight_aap.vault_credential_name if generate_env_vars_preflight is defined else generate_env_vars_prompt_aap_vault_cred.user_input %}
{% set generate_env_vars_aap_git_url = preflight_aap.git_url if generate_env_vars_preflight is defined else generate_env_vars_prompt_aap_project_scm_url.user_input %}
{% set generate_env_vars_aap_git_branch = preflight_aap.git_branch if generate_env_vars_preflight is defined else (generate_env_vars_prompt_aap_project_scm_branch.user_input | default('main', true)) %}
aap_version: {{ generate_env_vars_aap_version_number }}

controller_bootstrap_organization: "{{ generate_env_vars_aap_org }}"
controller_bootstrap_inventory_name: "{{ generate_env_vars_aap_inventory }}"
controller_bootstrap_project_name: "{{ generate_env_vars_aap_project }}"
controller_bootstrap_execution_environment_name: "{{ generate_env_vars_aap_ee }}"
controller_bootstrap_creds: "{{ generate_env_vars_aap_cred }}"

controller_bootstrap_controller_organizations:
  - name: "{{ generate_env_vars_aap_org }}"
    description: "{{ generate_env_vars_aap_org }}"

controller_bootstrap_controller_credentials:
  - name: "{{ generate_env_vars_aap_cred }}"
    description: "{{ generate_env_vars_aap_cred }}"
    organization: "{{ generate_env_vars_aap_org }}"
    credential_type: Vault
    inputs:
      vault_password: "{% raw %}{{ vault_controller_vault_password }}{% endraw %}"

controller_bootstrap_controller_projects:
  - name: "{{ generate_env_vars_aap_project }}"
    organization: "{{ generate_env_vars_aap_org }}"
    scm_type: git
    scm_url: "{{ generate_env_vars_aap_git_url }}"
    scm_branch: "{{ generate_env_vars_aap_git_branch }}"
    wait: true
    update_project: true

controller_bootstrap_controller_inventories:
  - name: "{{ generate_env_vars_aap_inventory }}"
    organization: "{{ generate_env_vars_aap_org }}"
    description: "Generated inventory"
    variables: {}

controller_bootstrap_controller_execution_environments:
  - name: "{{ generate_env_vars_aap_ee }}"
    image: quay.io/ansible/awx-ee:latest
    pull: missing

controller_bootstrap_controller_labels:
  - name: bootstrap
    organization: "{{ generate_env_vars_aap_org }}"
