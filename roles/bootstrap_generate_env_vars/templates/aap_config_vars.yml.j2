{% set bootstrap_generate_env_vars_hub_mark_ado_validated = true if bootstrap_generate_env_vars_hub_publish_ado_collection else false %}
{% set bootstrap_generate_env_vars_hub_force_ado_collection_update = preflight_aap.hub_force_ado_collection_update | default(bootstrap_generate_env_vars_hub_force_ado_collection_update | default(true)) | bool %}
{% set bootstrap_generate_env_vars_hub_update_collection_only = preflight_aap.hub_update_collection_only | default(bootstrap_generate_env_vars_hub_update_collection_only | default(false)) | bool %}
{% set bootstrap_generate_env_vars_aap_skip_tls_verify =
    preflight_aap.skip_tls_verify
    | default(skip_tls_verify | default(false), true)
    | bool
    if bootstrap_generate_env_vars_preflight is defined
    else (skip_tls_verify | default(false) | bool)
%}
{% set bootstrap_generate_env_vars_aap_validate_certs =
    (not bootstrap_generate_env_vars_aap_skip_tls_verify)
    if bootstrap_generate_env_vars_preflight is defined
    else (
      controller_validate_certs
      | default(not bootstrap_generate_env_vars_aap_skip_tls_verify)
      | bool
    )
%}

aap_version: {{ bootstrap_generate_env_vars_aap_version_number | trim }}

controller_validate_certs: {{ bootstrap_generate_env_vars_aap_validate_certs | lower }}
controller_verify_ssl: {{ bootstrap_generate_env_vars_aap_validate_certs | lower }}
tower_verify_ssl: {{ bootstrap_generate_env_vars_aap_validate_certs | lower }}
validate_certs: {{ bootstrap_generate_env_vars_aap_validate_certs | lower }}
verify_ssl: {{ bootstrap_generate_env_vars_aap_validate_certs | lower }}

controller_bootstrap_organization: "{{ bootstrap_generate_env_vars_aap_org }}"
controller_bootstrap_inventory_name: "{{ bootstrap_generate_env_vars_aap_inventory }}"
controller_bootstrap_project_name: "{{ bootstrap_generate_env_vars_aap_project }}"
controller_bootstrap_execution_environment_name: "{{ bootstrap_generate_env_vars_aap_ee }}"
bootstrap_controller_local_inventory_name: "{{ bootstrap_generate_env_vars_aap_inventory }}"
bootstrap_controller_rhel_inventory_name: "{{ bootstrap_generate_env_vars_rhel_inventory }}"
bootstrap_controller_idm_inventory_name: "{{ bootstrap_generate_env_vars_idm_inventory }}"
bootstrap_controller_satellite_inventory_name: "{{ bootstrap_generate_env_vars_satellite_inventory }}"
bootstrap_controller_cert_manager_mode: "{{ preflight_cert_manager_config.mode | default('cert', true) }}"

controller_bootstrap_creds: "{{ bootstrap_generate_env_vars_aap_cred }}"
controller_bootstrap_name_prefix: "{{ bootstrap_generate_env_vars_aap_org }}"
{% if bootstrap_generate_env_vars_machine_credential_enabled %}
controller_bootstrap_machine_credential: "{{ bootstrap_generate_env_vars_machine_credential_name }}"
{% endif %}

bootstrap_controller_hub_publish_ado_collection: {{ bootstrap_generate_env_vars_hub_publish_ado_collection | lower }}
bootstrap_controller_hub_mark_ado_validated: {{ bootstrap_generate_env_vars_hub_mark_ado_validated | lower }}
bootstrap_controller_hub_force_ado_collection_update: {{ bootstrap_generate_env_vars_hub_force_ado_collection_update | lower }}
bootstrap_controller_hub_update_collection_only: {{ bootstrap_generate_env_vars_hub_update_collection_only | lower }}
hub_collections:
{% if bootstrap_generate_env_vars_hub_publish_ado_collection %}
  - collection_name: infra_ado
    collection_local_path: "{{ bootstrap_generate_env_vars_hub_ado_collection_path | default('.') }}"
    repository: "validated"
{% else %}
  []
{% endif %}

controller_bootstrap_controller_organizations:
  - name: "{{ bootstrap_generate_env_vars_aap_org }}"
    description: "{{ bootstrap_generate_env_vars_aap_org }}"

controller_bootstrap_controller_credentials:
{% if bootstrap_generate_env_vars_aap_git_token_present %}
  - name: "{{ controller_bootstrap_scm_credential }}"
    description: "Git token credential for {{ bootstrap_generate_env_vars_aap_project }}"
    organization: "{{ bootstrap_generate_env_vars_aap_org }}"
    credential_type: Source Control
    inputs:
      username: "oauth2"
      password: "{% raw %}{{ '{{ vault_controller_git_token }}' }}{% endraw %}"
{% endif %}

  - name: "{{ bootstrap_generate_env_vars_aap_cred }}"
    description: "{{ bootstrap_generate_env_vars_aap_cred }}"
    organization: "{{ bootstrap_generate_env_vars_aap_org }}"
    credential_type: Vault
    inputs:
      vault_password: "{% raw %}{{ '{{ vault_controller_vault_password }}' }}{% endraw %}"
{% if bootstrap_generate_env_vars_machine_credential_enabled %}

  - name: "{{ bootstrap_generate_env_vars_machine_credential_name }}"
    description: "Machine credential for RHEL, Satellite, and patching jobs"
    organization: "{{ bootstrap_generate_env_vars_aap_org }}"
    credential_type: Machine
    inputs:
      username: "{% raw %}{{ '{{ vault_machine_credential_username }}' }}{% endraw %}"
      ssh_key_data: "{% raw %}{{ '{{ vault_machine_credential_ssh_key_data }}' }}{% endraw %}"
      ssh_key_unlock: "{% raw %}{{ '{{ vault_machine_credential_ssh_key_unlock }}' }}{% endraw %}"
      become_method: "{% raw %}{{ '{{ vault_machine_credential_become_method }}' }}{% endraw %}"
      become_username: "{% raw %}{{ '{{ vault_machine_credential_become_username }}' }}{% endraw %}"
{% endif %}
{% if bootstrap_generate_env_vars_satellite_dynamic_inventory_enabled %}

  - name: "{{ bootstrap_generate_env_vars_satellite_credential_name }}"
    description: "Satellite dynamic inventory credential"
    organization: "{{ bootstrap_generate_env_vars_aap_org }}"
    credential_type: Red Hat Satellite 6
    inputs:
      host: "{{ bootstrap_generate_env_vars_satellite_server_url }}"
      username: "{% raw %}{{ '{{ vault_satellite_service_account_username }}' }}{% endraw %}"
      password: "{% raw %}{{ '{{ vault_satellite_service_account_password }}' }}{% endraw %}"
{% endif %}
{% for extra_credential in bootstrap_generate_env_vars_aap_additional_credentials %}
{% if extra_credential.name | default('', true) | length > 0 %}
{% set extra_credential_vault_ref = 'vault_aap_additional_credentials[' ~ loop.index0 ~ ']' %}
{% set extra_credential_type = extra_credential.credential_type | default('Machine', true) %}
{% set extra_credential_raw_name = extra_credential.name | replace(' ', '-') %}
{% set extra_credential_name =
    extra_credential_raw_name
    if extra_credential_raw_name.startswith(bootstrap_generate_env_vars_aap_org ~ '-')
    else bootstrap_generate_env_vars_aap_org ~ '-' ~ extra_credential_raw_name
%}

  - name: "{{ extra_credential_name }}"
    description: "{{ extra_credential.description | default('Additional AAP credential', true) }}"
    organization: "{{ extra_credential.organization | default(bootstrap_generate_env_vars_aap_org, true) }}"
    credential_type: "{{ extra_credential_type }}"
    inputs:
{% if extra_credential_type == 'Vault' %}
{% if extra_credential.vault_password | default('', true) | length > 0 %}
      vault_password: "{% raw %}{{ '{{ {% endraw %}{{ extra_credential_vault_ref }}.vault_password{% raw %} }}' }}{% endraw %}"
{% elif extra_credential.password | default('', true) | length > 0 %}
      vault_password: "{% raw %}{{ '{{ {% endraw %}{{ extra_credential_vault_ref }}.password{% raw %} }}' }}{% endraw %}"
{% endif %}
{% elif extra_credential_type == 'Red Hat Satellite 6' %}
{% if extra_credential.host | default('', true) | length > 0 %}
      host: "{% raw %}{{ '{{ {% endraw %}{{ extra_credential_vault_ref }}.host{% raw %} }}' }}{% endraw %}"
{% endif %}
{% if extra_credential.username | default('', true) | length > 0 %}
      username: "{% raw %}{{ '{{ {% endraw %}{{ extra_credential_vault_ref }}.username{% raw %} }}' }}{% endraw %}"
{% endif %}
{% if extra_credential.password | default('', true) | length > 0 %}
      password: "{% raw %}{{ '{{ {% endraw %}{{ extra_credential_vault_ref }}.password{% raw %} }}' }}{% endraw %}"
{% endif %}
{% elif extra_credential_type == 'Source Control' %}
{% if extra_credential.username | default('', true) | length > 0 %}
      username: "{% raw %}{{ '{{ {% endraw %}{{ extra_credential_vault_ref }}.username{% raw %} }}' }}{% endraw %}"
{% endif %}
{% if extra_credential.password | default('', true) | length > 0 %}
      password: "{% raw %}{{ '{{ {% endraw %}{{ extra_credential_vault_ref }}.password{% raw %} }}' }}{% endraw %}"
{% endif %}
{% if extra_credential.ssh_key_data | default('', true) | length > 0 %}
      ssh_key_data: |
        {% raw %}{{ '{{ {% endraw %}{{ extra_credential_vault_ref }}.ssh_key_data{% raw %} }}' }}{% endraw %}
{% endif %}
{% else %}
{% if extra_credential.username | default('', true) | length > 0 %}
      username: "{% raw %}{{ '{{ {% endraw %}{{ extra_credential_vault_ref }}.username{% raw %} }}' }}{% endraw %}"
{% endif %}
{% if extra_credential.password | default('', true) | length > 0 %}
