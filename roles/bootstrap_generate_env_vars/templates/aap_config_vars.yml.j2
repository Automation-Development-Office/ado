{% set preflight_aap = bootstrap_generate_env_vars_preflight.aap | default({}) if bootstrap_generate_env_vars_preflight is defined else {} %}
{% set preflight_git = bootstrap_generate_env_vars_preflight.git | default({}) if bootstrap_generate_env_vars_preflight is defined else {} %}
---
{% set bootstrap_generate_env_vars_aap_org = preflight_aap.organization if bootstrap_generate_env_vars_preflight is defined else bootstrap_generate_env_vars_prompt_aap_org.user_input %}
{% set bootstrap_generate_env_vars_aap_inventory = preflight_aap.inventory if bootstrap_generate_env_vars_preflight is defined else bootstrap_generate_env_vars_prompt_aap_inventory.user_input %}
{% set bootstrap_generate_env_vars_aap_project = preflight_aap.project if bootstrap_generate_env_vars_preflight is defined else bootstrap_generate_env_vars_prompt_aap_project.user_input %}
{% set bootstrap_generate_env_vars_aap_ee = preflight_aap.execution_environment if bootstrap_generate_env_vars_preflight is defined else (bootstrap_generate_env_vars_prompt_aap_ee.user_input | default('ee-supported-rhel9', true)) %}
{% set bootstrap_generate_env_vars_aap_cred = preflight_aap.vault_credential_name if bootstrap_generate_env_vars_preflight is defined else bootstrap_generate_env_vars_prompt_aap_vault_cred.user_input %}
{% set bootstrap_generate_env_vars_aap_git_url = preflight_aap.git_url if bootstrap_generate_env_vars_preflight is defined else bootstrap_generate_env_vars_prompt_aap_project_scm_url.user_input %}
{% set bootstrap_generate_env_vars_aap_git_branch = preflight_aap.git_branch if bootstrap_generate_env_vars_preflight is defined else (bootstrap_generate_env_vars_prompt_aap_project_scm_branch.user_input | default('main', true)) %}
{% set bootstrap_generate_env_vars_aap_git_token_present = (preflight_git.token | default('') | length > 0) if bootstrap_generate_env_vars_preflight is defined else (bootstrap_generate_env_vars_prompt_aap_project_scm_token.user_input | default('', true) | length > 0) %}
{% set bootstrap_generate_env_vars_git_auto_push =
    (preflight_git.auto_push | default(false))
    if bootstrap_generate_env_vars_preflight is defined
    else ((bootstrap_generate_env_vars_prompt_git_auto_push.user_input | default('n', true) | lower) in ['y', 'yes'])
%}
{% set controller_bootstrap_scm_credential = bootstrap_generate_env_vars_aap_project ~ '-git-token' %}

aap_version: {{ bootstrap_generate_env_vars_aap_version_number }}

controller_bootstrap_organization: "{{ bootstrap_generate_env_vars_aap_org }}"
controller_bootstrap_inventory_name: "{{ bootstrap_generate_env_vars_aap_inventory }}"
controller_bootstrap_project_name: "{{ bootstrap_generate_env_vars_aap_project }}"
controller_bootstrap_execution_environment_name: "{{ bootstrap_generate_env_vars_aap_ee }}"

controller_bootstrap_creds: "{{ bootstrap_generate_env_vars_aap_cred }}"

controller_bootstrap_controller_organizations:
  - name: "{{ bootstrap_generate_env_vars_aap_org }}"
    description: "{{ bootstrap_generate_env_vars_aap_org }}"

controller_bootstrap_controller_credentials:
{% if bootstrap_generate_env_vars_aap_git_token_present %}
  - name: "{{ controller_bootstrap_scm_credential }}"
    description: "Git token credential for {{ bootstrap_generate_env_vars_aap_project }}"
    organization: "{{ bootstrap_generate_env_vars_aap_org }}"
    credential_type: Source Control
    inputs:
      username: "oauth2"
      password: "{% raw %}{{ vault_controller_git_token }}{% endraw %}"
{% endif %}

  - name: "{{ bootstrap_generate_env_vars_aap_cred }}"
    description: "{{ bootstrap_generate_env_vars_aap_cred }}"
    organization: "{{ bootstrap_generate_env_vars_aap_org }}"
    credential_type: Vault
    inputs:
      vault_password: "{% raw %}{{ vault_controller_vault_password }}{% endraw %}"

controller_bootstrap_controller_projects:
  - name: "{{ bootstrap_generate_env_vars_aap_project }}"
    organization: "{{ bootstrap_generate_env_vars_aap_org }}"
    scm_type: git
    scm_url: "{{ bootstrap_generate_env_vars_aap_git_url }}"
    scm_branch: "{{ bootstrap_generate_env_vars_aap_git_branch }}"
{% if bootstrap_generate_env_vars_aap_git_token_present %}
    credential: "{{ controller_bootstrap_scm_credential }}"
{% endif %}
    wait: true
    update_project: true

controller_bootstrap_controller_inventories:
  - name: "{{ bootstrap_generate_env_vars_aap_inventory }}"
    organization: "{{ bootstrap_generate_env_vars_aap_org }}"
    description: "Generated inventory"
    variables: {}

controller_bootstrap_controller_execution_environments:
  - name: "{{ bootstrap_generate_env_vars_aap_ee }}"
    image: quay.io/ansible/awx-ee:latest
    pull: missing

controller_bootstrap_controller_labels:
  - name: bootstrap
    organization: "{{ bootstrap_generate_env_vars_aap_org }}"

generate_playbook_repo_git_mode: "{{ 'push' if bootstrap_generate_env_vars_git_auto_push else 'manual' }}"
generate_playbook_repo_git_push: "{{ bootstrap_generate_env_vars_git_auto_push }}"
generate_playbook_repo_git_commit: "{{ bootstrap_generate_env_vars_git_auto_push }}"
generate_playbook_repo_pause_for_push: "{{ not bootstrap_generate_env_vars_git_auto_push }}"
generate_playbook_repo_git_url: "{{ bootstrap_generate_env_vars_aap_git_url }}"
generate_playbook_repo_git_branch: "{{ bootstrap_generate_env_vars_aap_git_branch }}"
generate_playbook_repo_git_remote: "origin"
generate_playbook_repo_git_username: "oauth2"
generate_playbook_repo_git_token: "{% raw %}{{ vault_controller_git_token }}{% endraw %}"
