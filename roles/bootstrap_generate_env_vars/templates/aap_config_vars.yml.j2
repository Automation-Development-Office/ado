{% endif %}
{% if extra_credential.token | default('', true) | length > 0 %}
      bearer_token: "{% raw %}{{ '{{ {% endraw %}{{ extra_credential_vault_ref }}.token{% raw %} }}' }}{% endraw %}"
      token: "{% raw %}{{ '{{ {% endraw %}{{ extra_credential_vault_ref }}.token{% raw %} }}' }}{% endraw %}"
{% endif %}
{% if extra_credential.ssh_key_data | default('', true) | length > 0 %}
      ssh_key_data: |
        {% raw %}{{ '{{ {% endraw %}{{ extra_credential_vault_ref }}.ssh_key_data{% raw %} }}' }}{% endraw %}
{% endif %}
{% if extra_credential.ssh_key_unlock | default('', true) | length > 0 %}
      ssh_key_unlock: "{% raw %}{{ '{{ {% endraw %}{{ extra_credential_vault_ref }}.ssh_key_unlock{% raw %} }}' }}{% endraw %}"
{% endif %}
{% if extra_credential.become_method | default('', true) | length > 0 %}
      become_method: "{% raw %}{{ '{{ {% endraw %}{{ extra_credential_vault_ref }}.become_method{% raw %} }}' }}{% endraw %}"
{% endif %}
{% if extra_credential.become_username | default('', true) | length > 0 %}
