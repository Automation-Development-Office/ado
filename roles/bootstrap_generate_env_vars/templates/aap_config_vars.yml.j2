    | regex_replace('/.*$', '')
%}
{% set bootstrap_generate_env_vars_idm_hostname = preflight_idm_config.hostname | default('', true) %}
{% set bootstrap_generate_env_vars_idm_replica_hostname = preflight_idm_config.replica_hostname | default('', true) %}
{% set bootstrap_generate_env_vars_openshift_api_host =
    preflight_openshift_config.api_host
    | default(preflight_openshift_config.host | default('', true), true)
%}
