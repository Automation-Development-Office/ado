{% set bootstrap_generate_env_vars_rhel_hosts_raw = [bootstrap_generate_env_vars_rhel_hosts_raw] %}
{% endif %}
{% set bootstrap_generate_env_vars_rhel_hosts = ([bootstrap_generate_env_vars_rhel_hostname] + bootstrap_generate_env_vars_rhel_hosts_raw) | select | unique | list %}
{% set bootstrap_generate_env_vars_satellite_inventory_host =
