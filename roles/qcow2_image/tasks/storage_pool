- name: Create shared storage pool
  become: true
  community.libvirt.virt_pool:
    name: "{{ cluster.clusterpool }}"
    state: present
    autostart: true

- name: Create the NFS storage pool on node
  become: true
  community.libvirt.virt_pool:
    name: "{{ storage_pool_name }}"
    state: defined
    storage:
      type: nfs
      source: "{{ nfs_server_ip }}:{{ nfs_export_path }}"
      target: "{{ storage_pool_target_path }}"
      permission: "0777"  # Permissions for the storage pool
    validate_certs: no

- name: Start the NFS storage pool on node
  become: true
  community.libvirt.virt_pool:
    name: "{{ storage_pool_name }}"
    state: started
    autostart: "{{ cluster_storagepool_pool_autostart}}| default ('true')"
    validate_certs: no

- name: Verify the storage pool status
  become: true
  command: virsh pool-list --all
  register: pool_status
  failed_when: "'{{ storage_pool_name }}' not in pool_status.stdout"
  changed_when: false