---
version: 3
images:
  base_image:
    name: "{{ aap_build_ee_base_image }}"
{% if aap_build_ee_package_manager_path | default('', true) | trim | length > 0 %}
options:
  package_manager_path: "{{ aap_build_ee_package_manager_path }}"
{% endif %}
{% if aap_build_ee_collection_files | length > 0 %}
additional_build_files:
{% for collection_file in aap_build_ee_collection_files %}
  - src: "{{ collection_file }}"
    dest: "collection-artifacts"
{% endfor %}
{% endif %}
dependencies:
{% if aap_build_ee_ansible_core | default('', true) | trim | length > 0 %}
  ansible_core:
    package_pip: "{{ __aap_build_ee_ansible_core_pip }}"
{% endif %}
{% if aap_build_ee_ansible_runner | default('', true) | trim | length > 0 %}
  ansible_runner:
    package_pip: "{{ __aap_build_ee_ansible_runner_pip }}"
{% endif %}
  galaxy: requirements.yml
