---
collections:
{% for collection_name, collection_version in aap_build_ee_collections.items() %}
  - name: "{{ collection_name }}"
{% if collection_version | string | trim | length > 0 %}
    version: "{{ collection_version }}"
{% endif %}
{% endfor %}
{% for collection_file in aap_build_ee_collection_files %}
  - name: "{{ 'collection-artifacts/' ~ (collection_file | basename) }}"
    type: file
{% endfor %}
