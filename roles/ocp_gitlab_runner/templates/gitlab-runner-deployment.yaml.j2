# gitlab-runner-deployment.yaml.j2
apiVersion: apps/v1
kind: Deployment
metadata:
  name: gitlab-runner
  namespace: {{ name_space }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: gitlab-runner
  template:
    metadata:
      labels:
        app: gitlab-runner
    spec:
      serviceAccountName: gitlab-runner
      containers:
        - name: runner
          image: {{ image }}
          command: ["/bin/sh","-ec"]  # -e fail fast, -c run string
          args:
            - >
              gitlab-runner register --non-interactive
              --url {{ gitlab_url | quote }}
              --token {{ runner_token | quote }}
              --executor kubernetes
              --kubernetes-namespace {{ name_space | quote }}
              --kubernetes-privileged=true
              --name {{ runner_name | quote }}
              && gitlab-runner run
          volumeMounts:
            - name: runner-config
              mountPath: /etc/gitlab-runner
      volumes:
        - name: runner-config
          emptyDir: {}

